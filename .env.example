# APP_URL: The URL where this app is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:5173"

# ------------------------------------------------------------
# NOTE: AI model API keys (LLM) are NO LONGER configured here.
# Users configure their own LLM (Wenxin, Qianwen, OpenAI, DeepSeek, etc.)
# directly in the Settings page of the app. Keys are stored in
# localStorage via Zustand and passed securely to the Python worker.
# ------------------------------------------------------------

# PEXELS_API_KEY: Fallback server-side key for fetching stock videos.
# Users can also configure this in the Settings page.
PEXELS_API_KEY="TODO_PEXELS_KEY"

# CAPCUT_API_KEY: Fallback server-side key for CapCut / JianYing integration.
# Users can also configure this in the Settings page.
CAPCUT_API_KEY="TODO_CAPCUT_KEY"
CAPCUT_API_BASE_URL="https://open.capcut.com"

# Redis connection (used by Node.js API gateway and Python worker)
REDIS_URL="redis://localhost:6379"

# SQLite database file path (used by Node.js API gateway)
DB_PATH="./db/videoturbo.db"

# Output directory for rendered video files
OUTPUT_DIR="./output"
